# =============================================================================
# КОРНЕВОЙ ШАБЛОН — скопируйте в .env и заполните SECRETS.
#
# run_all.py загружает только этот корневой .env (load_dotenv); парсеры читают os.environ
# через config.py. Локальные файлы sources/<источник>/.env.example не подгружаются кодом —
# это подсказки: скопируйте нужные переменные оттуда сюда вручную.
#
# Подробные переменные и пояснения по каждому источнику:
#   sources/scholarship_america/.env.example
#   sources/simpler_grants_gov/.env.example
#   sources/bigfuture/.env.example
#
# Включение источника: PARSER_SOURCES + соответствующий *_ENABLED=1 (см. run_all.py).
# Алиасы в PARSER_SOURCES: simpler → simpler_grants_gov, sa|scholarship → scholarship_america, bf → bigfuture.
# =============================================================================

# -----------------------------------------------------------------------------
# GLOBAL RUN
# -----------------------------------------------------------------------------
PARSER_SOURCES=scholarship_america

TARGET_NEW_ITEMS=50
MAX_LIST_PAGES=1000
NO_NEW_PAGES_STOP=50
SKIP_EXISTING_ON_LIST=1
USE_TITLE_FALLBACK_KNOWN=0
DISCOVERY_MODE=new_only

# -----------------------------------------------------------------------------
# SOURCES ENABLE (run_all пропускает источник при *_ENABLED=0)
# -----------------------------------------------------------------------------
SCHOLARSHIP_AMERICA_ENABLED=1
SIMPLER_ENABLED=1
BIGFUTURE_ENABLED=0
# BigFuture: см. sources/bigfuture/.env.example. Кратко:
# BIGFUTURE_AUTO_PIPELINE=1 — за один запуск: fast prefilter → deep из JSON store (по умолчанию 1).
# BIGFUTURE_FAST_MAX_PAGES=0 — лимит страниц только для fast-фазы (0 = MAX_LIST_PAGES).
# BIGFUTURE_DEEP_MAX_ITEMS=0 — лимит кандидатов deep из store (0 = без доп. ограничения).

# -----------------------------------------------------------------------------
# SCHOLARSHIP AI FINAL (все источники; перед upsert, см. supabase/migrations/*ai_finalization*)
# -----------------------------------------------------------------------------
# После миграции БД: SCHOLARSHIP_AI_FINAL_ENABLED=1 и OPENAI_API_KEY в SECRETS.
SCHOLARSHIP_AI_FINAL_ENABLED=0
SCHOLARSHIP_AI_MODEL=gpt-4o-mini
SCHOLARSHIP_AI_MAX_INPUT_CHARS=24000
SCHOLARSHIP_AI_WRITE_SEO=1
SCHOLARSHIP_AI_WRITE_SCORE=1
SCHOLARSHIP_AI_WRITE_GUIDANCE=1

# -----------------------------------------------------------------------------
# SECRETS
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me
OPENAI_API_KEY=

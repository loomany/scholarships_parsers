# =============================================================================
# КОРНЕВОЙ ШАБЛОН ПЕРЕМЕННЫХ (run_all.py читает только корневой .env через load_dotenv).
#
# ВАЖНО: не активируйте одновременно несколько блоков «СЕРВИС: …» — для одного .env
# оставьте ровно один такой блок + SECRETS + при необходимости глобальные лимиты сверху.
#
# Railway: под каждый сервис — скопируйте ОДИН из блоков «СЕРВИС: …» ниже,
# подставьте SECRETS и при необходимости подкрутите лимиты (TARGET / MAX_LIST_PAGES).
#
# Алиасы PARSER_SOURCES: simpler → simpler_grants_gov, sa|scholarship → scholarship_america,
# bf → bigfuture, bold → bold_org.
#
# Включение источника: ключ в PARSER_SOURCES + соответствующий *_ENABLED=1 (см. run_all.py).
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS (нужны всем парсерам, пишущим в Supabase и вызывающим OpenAI)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me
OPENAI_API_KEY=

# Опционально: вывести в лог переменные с префиксом (отладка; см. run_all.py)
# PARSER_DEBUG_ENV_PREFIX=SUPABASE

# -----------------------------------------------------------------------------
# ГЛОБАЛЬНЫЙ RUN (общие лимиты и режим discovery; читает config.GlobalConfig)
# -----------------------------------------------------------------------------
# Список источников через запятую или all
# PARSER_SOURCES=scholarship_america
TARGET_NEW_ITEMS=50
MAX_LIST_PAGES=1000
NO_NEW_PAGES_STOP=50
# 1 — на листинге пропускать уже известные строки (см. listing_is_known в utils.py)
SKIP_EXISTING_ON_LIST=1
# 1 — доп. матч по нормализованному title, если source_id/url/slug не совпали
USE_TITLE_FALLBACK_KNOWN=0
# new_only — только новые; all — полный обход (зависит от парсера)
DISCOVERY_MODE=new_only

# Бизнес-фильтр: минимум полных дней до дедлайна (business_filters.MIN_LEAD_DAYS_BEFORE_DEADLINE)
MIN_LEAD_DAYS=3

# -----------------------------------------------------------------------------
# SCHOLARSHIP AI FINAL (перед upsert для всех источников; config.ScholarshipsAiFinalConfig)
# -----------------------------------------------------------------------------
SCHOLARSHIP_AI_FINAL_ENABLED=0
SCHOLARSHIP_AI_MODEL=gpt-4o
SCHOLARSHIP_AI_MAX_INPUT_CHARS=5000
SCHOLARSHIP_AI_WRITE_SEO=1
SCHOLARSHIP_AI_WRITE_SCORE=1
SCHOLARSHIP_AI_WRITE_GUIDANCE=1

# -----------------------------------------------------------------------------
# REPEATER (опционально: бесконечный цикл repeater.py → EXECUTE_SCRIPT)
# -----------------------------------------------------------------------------
# EXECUTE_SCRIPT=run_all.py
# REPEATER_SLEEP_HOURS=2
# REPEATER_HEARTBEAT_SECONDS=300
# REPEATER_CLEANUP_COMMAND=

# ##############################################################################
# СЕРВИС: Scholarship America (один Railway-сервис)
# Скопируйте отсюда до следующего «СЕРВИС:» + блок SECRETS выше.
# ##############################################################################
PARSER_SOURCES=scholarship_america
TARGET_NEW_ITEMS=50
MAX_LIST_PAGES=1000
NO_NEW_PAGES_STOP=50
SKIP_EXISTING_ON_LIST=1
USE_TITLE_FALLBACK_KNOWN=0
DISCOVERY_MODE=new_only
MIN_LEAD_DAYS=3

SCHOLARSHIP_AMERICA_ENABLED=1
SIMPLER_ENABLED=0
SIMPLER_GRANTS_GOV_ENABLED=0
BIGFUTURE_ENABLED=0
BOLD_ORG_ENABLED=0

# Потолок успешных upsert: min(TARGET_NEW_ITEMS, N). 0 = только TARGET_NEW_ITEMS.
SCHOLARSHIP_AMERICA_MAX_RECORDS_DEBUG=0
# 1 — тянуть HTML детальной страницы; 0 — только поля с листинга
SCHOLARSHIP_AMERICA_DETAIL_FETCH=1

# SCHOLARSHIP_AI_FINAL_* — см. общий блок
# OPENAI_API_KEY, SUPABASE_* — см. SECRETS

# ##############################################################################
# СЕРВИС: Simpler.Grants.gov (один Railway-сервис)
# ##############################################################################
PARSER_SOURCES=simpler
TARGET_NEW_ITEMS=50
MAX_LIST_PAGES=1000
NO_NEW_PAGES_STOP=50
SKIP_EXISTING_ON_LIST=1
USE_TITLE_FALLBACK_KNOWN=0
DISCOVERY_MODE=new_only
MIN_LEAD_DAYS=3

SCHOLARSHIP_AMERICA_ENABLED=0
# SIMPLER_GRANTS_GOV_ENABLED — старое имя fallback для SIMPLER_ENABLED
SIMPLER_ENABLED=1
SIMPLER_GRANTS_GOV_ENABLED=1
BIGFUTURE_ENABLED=0
BOLD_ORG_ENABLED=0

SIMPLER_MAX_RECORDS_DEBUG=30
SIMPLER_DETAIL_FETCH=1
SIMPLER_INCLUDE_EXTENDED_SEARCH=0
SIMPLER_AI_ENRICH_ENABLED=0
# Модель задаётся в коде (gpt-4o-mini); лимит символов на вход AI:
SIMPLER_AI_MAX_INPUT_CHARS=4500

# ##############################################################################
# СЕРВИС: BigFuture / College Board (один Railway-сервис)
# ##############################################################################
PARSER_SOURCES=bf
TARGET_NEW_ITEMS=50
MAX_LIST_PAGES=1000
NO_NEW_PAGES_STOP=50
SKIP_EXISTING_ON_LIST=1
USE_TITLE_FALLBACK_KNOWN=0
DISCOVERY_MODE=new_only
MIN_LEAD_DAYS=3

SCHOLARSHIP_AMERICA_ENABLED=0
SIMPLER_ENABLED=0
BIGFUTURE_ENABLED=1
BOLD_ORG_ENABLED=0

BIGFUTURE_ACTIVE_ONLY=1
BIGFUTURE_DETAIL_FETCH=1
BIGFUTURE_HEADLESS=1
BIGFUTURE_TIMEOUT_MS=120000
BIGFUTURE_MAX_RECORDS_DEBUG=30
BIGFUTURE_KEYWORD=
BIGFUTURE_FORCE_HTTP=0

BIGFUTURE_AI_ENRICH_ENABLED=0
BIGFUTURE_AI_MAX_INPUT_CHARS=4500

# Двухфазный pipeline: fast prefilter → deep из JSON store
BIGFUTURE_AUTO_PIPELINE=1
# 0 = для fast-фазы брать MAX_LIST_PAGES
BIGFUTURE_FAST_MAX_PAGES=0
# 0 = без отдельного лимита deep-кандидатов
BIGFUTURE_DEEP_MAX_ITEMS=0
BIGFUTURE_FAST_PREFILTER_ONLY=0
BIGFUTURE_DEEP_PASS_ONLY=0
BIGFUTURE_MIN_AMOUNT_HINT=500
# Пусто = путь по умолчанию .bigfuture_prefilter_store.json в корне проекта
BIGFUTURE_PREFILTER_STORE_PATH=
BIGFUTURE_RECHECK_REJECT_DAYS=1
BIGFUTURE_DEEP_INCLUDE_REVIEW=1

# ##############################################################################
# СЕРВИС: Bold.org (один Railway-сервис; локально часто с видимым браузером)
# ##############################################################################
PARSER_SOURCES=bold_org
TARGET_NEW_ITEMS=2000
MAX_LIST_PAGES=10000
NO_NEW_PAGES_STOP=0
SKIP_EXISTING_ON_LIST=1
USE_TITLE_FALLBACK_KNOWN=0
DISCOVERY_MODE=new_only
MIN_LEAD_DAYS=3

SCHOLARSHIP_AMERICA_ENABLED=0
SIMPLER_ENABLED=0
BIGFUTURE_ENABLED=0
BOLD_ORG_ENABLED=1

BOLD_EMAIL=
BOLD_PASSWORD=
BOLD_HEADLESS=1
BOLD_TIMEOUT_MS=180000
BOLD_SCROLL_STEPS=0
BOLD_SCROLL_WAIT_MS=2000
BOLD_NO_NEW_ROUNDS_STOP=6
BOLD_RECOVERY_SCROLL_ROUNDS=3
BOLD_RECOVERY_WAIT_MS=5000
BOLD_POST_LOGIN_WAIT_MS=3000
BOLD_KEEP_BROWSER_OPEN=0
BOLD_ORG_MAX_RECORDS_DEBUG=0
# 0 — уважать skip уже известных на листинге; 1 — форсировать перепроверку discovery
BOLD_FORCE_REFRESH=0
BOLD_PREFILTER_STORE_PATH=.bold_prefilter_store.json

# BigFuture (College Board) — скопируйте нужные строки в корневой .env (этот файл код не читает).

BIGFUTURE_ENABLED=1

# Листинг: отсекать карточки с closeDate строго до сегодня (до detail/AI).
BIGFUTURE_ACTIVE_ONLY=1

BIGFUTURE_DETAIL_FETCH=1
BIGFUTURE_HEADLESS=1
BIGFUTURE_TIMEOUT_MS=120000
BIGFUTURE_MAX_RECORDS_DEBUG=30
BIGFUTURE_KEYWORD=

BIGFUTURE_AI_ENRICH_ENABLED=0
BIGFUTURE_AI_MODEL=gpt-4o-mini
BIGFUTURE_AI_MAX_INPUT_CHARS=24000

# Двухфазный pipeline (list-префильтр в JSON, затем deep).
# BIGFUTURE_AUTO_PIPELINE=1 — один run(): сначала fast prefilter в store, затем deep pass из store.
# При AUTO=0 используйте только один из: BIGFUTURE_FAST_PREFILTER_ONLY=1 или BIGFUTURE_DEEP_PASS_ONLY=1.
BIGFUTURE_AUTO_PIPELINE=1
# Лимит страниц листинга только для fast-фазы (и для первой половины комбинированного ручного run).
# 0 = без отдельного лимита, берётся глобальный MAX_LIST_PAGES.
BIGFUTURE_FAST_MAX_PAGES=0
# Доп. лимит кандидатов только для deep-фазы (из store). 0 = только общая логика effective_target.
BIGFUTURE_DEEP_MAX_ITEMS=0

BIGFUTURE_FAST_PREFILTER_ONLY=0
BIGFUTURE_DEEP_PASS_ONLY=0
BIGFUTURE_MIN_AMOUNT_HINT=500
BIGFUTURE_PREFILTER_STORE_PATH=
BIGFUTURE_RECHECK_REJECT_DAYS=30
BIGFUTURE_DEEP_INCLUDE_REVIEW=1

# Unigo — Playwright + Cloudflare (см. sources/unigo/parser.py)
#
# Запуск: .\run_unigo_visible.ps1
# или: PARSER_SOURCES=unigo UNIGO_ENABLED=1 python -u -m sources.unigo.parser
#
UNIGO_ENABLED=1

# Свой уже открытый Chrome (нет баннера «автоматизированное ПО»): см. run_unigo_visible.ps1
# UNIGO_CDP_URL=http://127.0.0.1:9222
# UNIGO_CDP_USE_FIRST_TAB=0

# Видимый браузер (не включайте headless против Cloudflare)
UNIGO_HEADLESS=0
# Профиль на диске — cf_clearance переживает перезапуск (рядом с проектом: .unigo_browser_profile/)
UNIGO_USE_PERSISTENT_PROFILE=1
UNIGO_PLAYWRIGHT_CHANNEL=chrome
# UNIGO_BROWSER_PROFILE_DIR=C:\path\to\.unigo_browser_profile
# После первой вкладки: пройди Cloudflare в окне, затем Enter в терминале
UNIGO_REQUIRE_MANUAL_START=1
# Опционально: экспорт cookies в JSON (при профиле — дубликат полезной сессии)
# UNIGO_SAVE_STORAGE_STATE=1
#
# Если без persistent профиля — сохранённый state как у Scholarships.com
# UNIGO_SESSION_PATH=C:\path\to\unigo_session.json
#
# Страницы-листинги (CSV). По умолчанию в коде уже есть несколько /scholarships/…
# UNIGO_SEED_URLS=https://www.unigo.com/scholarships/high-school-students,https://www.unigo.com/scholarships/undergraduate-students
#
UNIGO_SCROLL_ROUNDS=4
UNIGO_SCROLL_WAIT_MS=1200
UNIGO_NAV_DELAY_MS=800
UNIGO_TIMEOUT_MS=90000
# Ограничить размер очереди детальных URL за прогон
UNIGO_MAX_DISCOVERED=800
#
# Логировать action из POST payload для admin-ajax.php (отладка)
# UNIGO_LOG_AJAX_ACTIONS=0
# Счётчик ссылок в DOM после каждого seed (отладка «почему 0 результатов»)
# UNIGO_DEBUG_LINKS=0
#
SKIP_EXISTING_ON_LIST=1
DISCOVERY_MODE=new_only
TARGET_NEW_ITEMS=50
MIN_LEAD_DAYS=3

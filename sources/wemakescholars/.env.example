# Скопируйте строки в корневой .env репозитория (см. README.md в scholarships_parsers).

# Включение в run_all: PARSER_SOURCES должен содержать wemakescholars (или all) И WEMAKE_SCHOLARS_ENABLED=1
WEMAKE_SCHOLARS_ENABLED=1
WEMAKE_SCHOLARS_DETAIL_FETCH=1
WEMAKE_SCHOLARS_REQUEST_DELAY_MS=600
WEMAKE_SCHOLARS_TIMEOUT_SECONDS=45
WEMAKE_SCHOLARS_MAX_RECORDS_DEBUG=0

# Потолок hub-страниц (listing), не карточек. 0 = фактически без лимита (до исчерпания очереди BFS).
# Не задано → берётся GlobalConfig.MAX_LIST_PAGES.
WEMAKE_SCHOLARS_MAX_HUB_PAGES=0

# Доп. hub URL без query (через запятую), для расширения discovery:
# WEMAKE_SCHOLARS_EXTRA_HUBS=https://www.wemakescholars.com/university/ie-university/scholarships
